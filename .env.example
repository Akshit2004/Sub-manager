# Next.js Backend REST API Configuration
# - API_BASE_URL: Development base URL (auto-mapped to 10.0.2.2 for Android emulators)
# - API_PRODUCTION_URL: Production hosted Next.js admin dashboard URL
API_BASE_URL=http://10.0.2.2:3000
API_PRODUCTION_URL=https://your-production-app.vercel.app

# MongoDB Connection Configuration (Legacy/Direct DB Connection Fallback)
MONGO_URI=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/sub_manager
MONGO_DB_NAME=sub_manager

# Email Notification Configuration (Gmail SMTP)
EMAIL_USER=your-email@gmail.com
EMAIL_PASS=your-gmail-app-password
